{
  "manifest_version": 3,
  "name": "Imposto Brasil",
  "version": "1.1.0",
  "description": "Mostra impostos embutidos em produtos no Mercado Livre e compara com preco nos EUA.",
  "homepage_url": "https://github.com/mastiico/imposto-brasil-extensao",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.mercadolivre.com.br/*",
    "https://economia.awesomeapi.com.br/*",
    "https://www.amazon.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.mercadolivre.com.br/*"
      ],
      "js": [
        "content/core/runtime.js",
        "content/core/format.js",
        "content/data/categories.js",
        "content/core/tax.js",
        "content/core/scraping.js",
        "content/services/international.js",
        "content/ui/overlay.js",
        "content/main.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "IBPT/*.csv"
      ],
      "matches": [
        "*://*.mercadolivre.com.br/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Imposto Brasil",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  }
}
